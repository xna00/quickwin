{
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "types": ["./quickwin.d.ts", "./lib/preact/jsx.d.ts"],
    "outDir": "_build",
    "jsx": "react-jsx",
    "jsxImportSource": "../lib/preact",
  },
  "include": ["test/**/*.ts", "examples/**/*.ts", "examples/**/*.tsx", "main.ts"],
  "exclude": []
}
